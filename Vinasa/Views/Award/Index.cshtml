
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/sbadmin.cshtml";
}

<!-- Page Heading -->
<h1 class="h3 mb-2 text-gray-800">Giải Thưởng</h1>

<!-- DataTales Example -->
<div class="card shadow mb-4">
    <div class="card-header py-3" style=" display: flex; justify-content: space-between; align-items: center;">
        <div class="right-content">
            <h6 class="m-0 font-weight-bold text-primary" style="color: #19315D ">Danh sách các giải thưởng</h6>
        </div>
        <div class="left-content">
            <button class="button-lc" onclick="location.href='@Url.Action("Create", "Award")'">Thêm Mới</button>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th >
                            Tên Giải Thưởng
                        </th>
                        <th>
                           Thời gian diễn ra
                        </th>
                        <th>
                            Địa điểm
                        </th>
                        <th class="action-column">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                  
                        <tr>
                            <td>
                                <a href="@Url.Action("Index","AwardParticipants")">
                                    Sao Khuê
                                </a>
                            </td>
                            <td>
                                11 Tháng 7
                            </td>
                            <td>
                                HCM
                            </td>
                            <td class="td-action" style="display:flex; justify-content:space-around; align-items:center">
                                <li class="action-item" style="list-style-type: none; font-size: 18px">
                                    <a class="action-icon" href="@Url.Action("Edit","Award")">
                                        <i class="fa-solid fa-pen-to-square icon"></i>
                                    </a>
                                </li>
                                <li class="action-item" style="list-style-type: none; font-size: 18px">
                                    <a class="action-icon delete-btn" data-id="">
                                        <i class="fa-solid fa-trash-can icon"></i>
                                    </a>
                                </li>
                            </td>
                        </tr>
                    
                </tbody>
            </table>
            <div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
                <div class="modal-dialog" role="document">
                </div>
            </div>
        </div>
    </div>
</div>
